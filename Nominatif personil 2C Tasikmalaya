function getStatusSmartCard(tglBerlaku){

    if(!tglBerlaku){
        return {
            text:"",
            color:""
        };
    }

    const today = new Date();
    const expired = new Date(tglBerlaku);

    const selisihHari =
        (expired - today) / (1000 * 60 * 60 * 24);

    if(selisihHari < 0){
        return {
            text:"KADALUWARSA",
            color:"#ff4d4d"
        };
    }

    if(selisihHari <= 183){
        return {
            text:"HAMPIR HABIS",
            color:"#ffd966"
        };
    }

    return {
        text:"BERLAKU",
        color:"#92d050"
    };
}


function getStatusPenempatan(lamaPenempatan){

    if(!lamaPenempatan){
        return "";
    }

    const match = lamaPenempatan.match(/(\d+)/);

    if(!match){
        return "";
    }

    const tahun = parseInt(match[1]);

    if(tahun <= 2){
        return "#92D050"; // Hijau
    }

    if(tahun <= 4){
        return "#FFD966"; // Kuning
    }

    return "#FF6666"; // Merah
}
